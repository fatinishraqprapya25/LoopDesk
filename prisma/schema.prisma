generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// user roles
enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// user status
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// project status
enum ProjectStatus {
  STARTED
  DELEVERED
  CANCELLED
}

// project block types
enum ProjectBlockTypes {
  HEADING1
  HEADING2
  HEADING3
  HEADING4
  PARAGRAPH
  NUMBERED_LIST
  BULLETED_LIST
  TASK_GROUP
}

// project role
enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String
  password       String
  role           UserRole
  avatar         String
  status         UserStatus
  lastLogin      DateTime?
  workspaces     Workspace[]
  projects       Project[]       @relation("ProjectCreator")
  projectMembers ProjectMember[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("users")
}

model Workspace {
  id          String    @id @default(uuid())
  name        String
  description String
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  userId      String

  @@map("workspaces")
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String
  thumbnail   String
  status      ProjectStatus
  createdBy   String
  user        User            @relation("ProjectCreator", fields: [createdBy], references: [id])
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  blocks      ProjectBlock[]
  members     ProjectMember[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectMember {
  id            String      @id @default(uuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  assignedTasks Task[]
  role          ProjectRole

  @@map("projectMembers")
}

model ProjectBlock {
  id        String            @id @default(uuid())
  position  Int
  type      ProjectBlockTypes
  projectId String
  project   Project           @relation(fields: [projectId], references: [id])
  tasks     Task[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("blocks")
}

model Task {
  id         String        @id @default(uuid())
  blockId    String
  block      ProjectBlock  @relation(fields: [blockId], references: [id])
  content    String
  memberId   String
  assignedTo ProjectMember @relation(fields: [memberId], references: [id])
}
